<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="CI Suite" parallel="false">

    <test name="Smoke + Regression">
        <groups>
            <run>
                <include name="smoke"/>
                <include name="regression"/>
                <exclude name="flaky"/>
            </run>
        </groups>
        <packages>
            <package name="tests.api.*"/>
        </packages>
    </test>

</suite>